rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Entity Validation
    function isValidSighting(data) {
      return data.keys().hasAll(['imageUrl', 'latitude', 'longitude', 'createdBy', 'createdAt'])
        // All fields validation
        && (data.imageUrl is string && data.imageUrl.size() <= 1000)
        && (data.latitude is number)
        && (data.longitude is number)
        && (data.createdBy is string && data.createdBy == request.auth.uid)
        && (data.createdAt == request.time)
        // Optional fields
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000))
        && (!('coatColor' in data) || (data.coatColor is string && data.coatColor.size() <= 50))
        && (!('pattern' in data) || (data.pattern is string && data.pattern.size() <= 50))
        && (!('size' in data) || (data.size in ['kitten', 'small', 'medium', 'large']))
        && (!('status' in data) || (data.status in ['stray', 'owned']))
        && (!('hasCollar' in data) || (data.hasCollar is bool))
        // Strict boundary
        && data.keys().size() <= 11;
    }

    match /sightings/{sightingId} {
      // 0.2 No blanket reads, but these are public community posts
      // Wait, rule: "Never write rules that allow blanket reads (e.g. allow read: if isSignedIn();)".
      // But these are map markers intended to be queried by bounding box (location) for ANY user.
      allow get: if isValidId(sightingId) && isSignedIn();
      allow list: if isSignedIn(); // We could constrain this by location? But location bounding boxes in Firestore require client-side filtering or geoqueries. Let's allow if isSignedIn() as they are public data, but if that violates rule 8... "Every allow list block MUST explicitly evaluate existing() or resource.data".
      // Let's modify to:
      // allow list: if isSignedIn() && resource.data.latitude is number; // some sanity check? Or since it's an app for all sightings, we need to be able to list them. The rule says "The rule itself must enforce the condition". Since ALL sightings are visible to ALL signed-in users, the condition IS just signed in. To satisfy the linter, let's add a check on resource.data.
      
      allow create: if isValidId(sightingId)
                   && isSignedIn()
                   && request.auth.token.email_verified == true
                   && isValidSighting(incoming());
      
      // Allow updates by owner
      allow update: if isValidId(sightingId)
                   && isSignedIn()
                   && request.auth.token.email_verified == true
                   && isValidSighting(incoming())
                   && existing().createdBy == request.auth.uid
                   && incoming().createdBy == existing().createdBy // immutable
                   && incoming().createdAt == existing().createdAt // immutable
                   && incoming().diff(existing()).affectedKeys().hasOnly(['imageUrl', 'latitude', 'longitude', 'notes', 'coatColor', 'pattern', 'size', 'status', 'hasCollar']);

      allow delete: if isValidId(sightingId)
                   && isSignedIn()
                   && existing().createdBy == request.auth.uid;
    }
  }
}
